{
  "name": "agentic-accounting",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "bootstrap": "npm install --workspaces --include-workspace-root",
    "build:api": "npm run build --workspace @agentic-accounting/api",
    "build:web": "npm run build --workspace @agentic-accounting/web",
    "test:api": "npm run test --workspace @agentic-accounting/api",
    "smoke:auth": "node infra/testing/auth-smoke.mjs",
    "test:db": "node infra/testing/db-smoke.mjs",
    "test:web": "npm run test --workspace @agentic-accounting/web",
    "dev:api": "npm run start:dev --workspace @agentic-accounting/api",
    "dev:web": "npm run dev --workspace @agentic-accounting/web",
    "start:api": "npm run start --workspace @agentic-accounting/api"
  }
}
